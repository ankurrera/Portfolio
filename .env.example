# Supabase Configuration
# Your Supabase Project Reference ID
VITE_SUPABASE_PROJECT_ID=your-project-reference-id-here

# Your Supabase Project API URL (found under Project Settings -> API)
VITE_SUPABASE_URL=https://your-project-reference-id-here.supabase.co

# Supabase Anon/Publishable Key (found under Project Settings -> API)
# Used by both Vite frontend client and migration scripts
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-publishable-key-here
VITE_SUPABASE_ANON_KEY=your-supabase-anon-publishable-key-here

# Supabase Service Role Key (found under Project Settings -> API -> service_role)
# CRITICAL: Keep this secure! Only used by serverless functions (like upload API) and backend migrations
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Email SMTP Configuration (Gmail)
# Official email address where contact form submissions will be received
OFFICIAL_EMAIL=ankurrera@gmail.com

# Gmail address used to authenticate SMTP server
GMAIL_USER=ankurr.tf@gmail.com

# Gmail App Password (NOT your regular password)
# Generate from: https://myaccount.google.com/apppasswords
GMAIL_PASSWORD=your_gmail_app_password_here
